# Lokale Entwicklungsumgebung — Live-Server spiegeln
# Kopiere diese Datei nach .env.local und trage die Werte ein.
# .env.local ist in .gitignore und wird nie committet.

# Öffentliche URL des Live-Servers (für og:image, canonical, Sitemap)
SITE_URL=http://localhost:4333

# Live-Server-URL für den Bild-Proxy im Dev-Server
# Alle /cms/-Anfragen werden an diesen Server weitergeleitet
LIVE_SERVER_URL=https://patricks309.sg-host.com

# FTP-Zugangsdaten für sync-cms.sh
FTP_SERVER=patricks309.sg-host.com
FTP_USERNAME=dein-ftp-benutzer
FTP_PASSWORD=dein-ftp-passwort
FTP_CMS_PATH=/cms/user/
