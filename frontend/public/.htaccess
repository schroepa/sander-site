# ─── Cache-Control für statische Assets ───────────────────────────────────────
# Fonts: 1 Jahr (ändern sich praktisch nie)
<FilesMatch "\.(woff2|woff|ttf|otf)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Bilder: 1 Woche
<FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico)$">
  Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
</FilesMatch>

# CSS & JS: 1 Jahr (Astro hashed filenames = safe)
<FilesMatch "\.(css|js)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
