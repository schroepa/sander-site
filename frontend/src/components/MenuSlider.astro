---
import type { MenuSliderData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
  data: MenuSliderData;
}

const { data } = Astro.props;
const { headline, items = [] } = data;
---

<section class="menu-slider" id="menu-slider-section">
  <div class="menu-slider__inner">
    {
      headline && (
        <div class="menu-slider__header">
          <h2 class="menu-slider__headline">{headline}</h2>
        </div>
      )
    }

    <div class="embla-wrapper">
      <div class="embla" id="menuSlider">
        <div class="embla__viewport">
          <div class="embla__container">
            {
              items.map((item, index) => {
                // filepicker/mediapicker can return:
                //   "slider1.png"           → bare filename (correct)
                //   "/home/slider1.png"     → mediapicker adds /home/ prefix (must strip)
                //   {filename: {...}}       → legacy file-upload object
                function resolveFilename(raw: string | object | undefined): string {
                  if (!raw) return "";
                  if (typeof raw === "object") return Object.keys(raw)[0] ?? "";
                  return (raw as string).replace(/^\/?home\//, "");
                }

                const videoFilename = resolveFilename(item.video);
                const videoUrl = videoFilename ? `${GRAV_MEDIA_BASE}/${videoFilename}` : "";

                const imageFilename = !videoUrl ? resolveFilename(item.image) : "";
                const imageUrl = imageFilename ? `${GRAV_MEDIA_BASE}/${imageFilename}` : "";

                return (
                  <div class="embla__slide">
                    <div class="menu-slide">
                      {videoUrl ? (
                        <video
                          src={videoUrl}
                          autoplay
                          muted
                          loop
                          playsinline
                          preload="none"
                          class="menu-slide__image"
                        />
                      ) : imageUrl ? (
                        <img
                          src={imageUrl}
                          alt={item.title}
                          class="menu-slide__image"
                          loading="lazy"
                          decoding={index === 0 ? "sync" : "async"}
                        />
                      ) : null}
                      <div class="menu-slide__overlay">
                        <div class="menu-slide__content">
                          <h3 class="menu-slide__title">{item.title}</h3>
                          {item.subtitle && (
                            <p class="menu-slide__subtitle">{item.subtitle}</p>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>

      <!-- Buttons kommen nach .embla im DOM, damit sie über den Slides liegen -->
      <button class="embla__btn embla__btn--prev" aria-label="Vorheriges Bild">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
      </button>
      <button class="embla__btn embla__btn--next" aria-label="Nächstes Bild">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .menu-slider {
    padding: var(--space-1000) 0;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-bg-app);
    min-height: 400px;
  }

  .menu-slider__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-1000);
  }

  /* ─── Header ─── */
  .menu-slider__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-200);
    align-items: center;
    text-align: center;
    padding: 0 var(--space-800);
  }

  .menu-slider__headline {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-display-sm);
    line-height: var(--leading-display-sm);
    color: var(--color-text-primary);
    letter-spacing: 1px;
    text-transform: uppercase;
    max-width: 960px;
    margin: 0;
  }

  .embla-wrapper {
    position: relative;
    width: 100%;
  }

  .embla {
    overflow: hidden;
    width: 100%;
    cursor: grab;
  }

  .embla:active {
    cursor: grabbing;
  }

  /* ─── Nav Buttons ─── */
  .embla__btn {
    display: none; /* touch-first: only show for pointer devices */
  }

  @media (pointer: fine) {
    .embla__btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: none;
      background-color: rgba(0, 0, 0, 0.55);
      color: #fff;
      cursor: pointer;
      transition:
        background-color 0.2s ease,
        transform 0.2s ease;
    }

    .embla__btn:hover {
      background-color: rgba(0, 0, 0, 0.8);
      transform: translateY(-50%) scale(1.08);
    }

    .embla__btn--prev {
      left: var(--space-400);
    }

    .embla__btn--next {
      right: var(--space-400);
    }
  }

  .embla__viewport {
    /* No padding — slides flush to edge, gap controls spacing uniformly */
  }

  .embla__container {
    display: flex;
    backface-visibility: hidden;
    will-change: transform;
    gap: var(--space-500);
  }

  .embla__slide {
    flex: 0 0 85%;
    min-width: 0;
    position: relative;
  }

  @media (min-width: 768px) {
    .embla__slide {
      flex: 0 0 50%;
    }
  }

  @media (min-width: 1200px) {
    .embla__slide {
      flex: 0 0 32%;
    }
  }

  .menu-slide {
    position: relative;
    height: 60svh;
    border-radius: var(--radius-300);
    overflow: hidden;
    background-color: var(--color-background-tertiary);
    box-shadow: var(--shadow-xxl);
    transform: translateZ(0); /* Hardware acceleration */
  }

  @media (min-width: 768px) {
    .menu-slide {
      height: 80svh;
    }
  }

  .menu-slide__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .menu-slide:hover .menu-slide__image {
    transform: scale(1.08);
  }

  .menu-slide__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--color-background-overlay) 0%,
      var(--color-bg-overlay) 45%,
      transparent 100%
    );
    display: flex;
    align-items: flex-end;
    padding: var(--space-500);
  }

  .menu-slide__content {
    color: white;
    transform: translateY(10px);
    transition: transform 0.4s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .menu-slide:hover .menu-slide__content {
    transform: translateY(0);
  }

  .menu-slide__title {
    font-family: var(--font-body);
    font-size: var(--text-h4);
    line-height: var(--leading-h4);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-050);
  }

  .menu-slide__subtitle {
    font-family:
      "Geist",
      system-ui,
      -apple-system,
      sans-serif;
    font-size: var(--text-body-md);
    line-height: var(--leading-body-md);
    font-weight: var(--weight-regular);
    color: var(--color-text-secondary);
    opacity: 0.9;
    max-width: 100%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";
  import type { EmblaCarouselType } from "embla-carousel";

  let emblaInstance: EmblaCarouselType | null = null;

  const initSlider = () => {
    // Destroy existing instance before re-initializing to prevent
    // multiple instances from attaching duplicate event listeners
    if (emblaInstance) {
      emblaInstance.destroy();
      emblaInstance = null;
    }

    const root = document.querySelector("#menuSlider");
    if (!root) return;

    const viewport = root.querySelector(".embla__viewport") as HTMLElement;
    if (!viewport) return;

    emblaInstance = EmblaCarousel(viewport, {
      loop: true,
      align: "start" as const,
    });
  };

  // Wire up prev/next buttons once — they close over emblaInstance,
  // so re-initializing the slider doesn't require re-binding the buttons.
  const setupButtons = () => {
    const wrapper = document.querySelector(".embla-wrapper");
    if (!wrapper) return;
    wrapper
      .querySelector(".embla__btn--prev")
      ?.addEventListener("click", () => emblaInstance?.scrollPrev());
    wrapper
      .querySelector(".embla__btn--next")
      ?.addEventListener("click", () => emblaInstance?.scrollNext());
  };

  // Run on initial load
  initSlider();
  setupButtons();

  // Destroy before Astro swaps the DOM to avoid stale listeners
  document.addEventListener("astro:before-swap", () => {
    if (emblaInstance) {
      emblaInstance.destroy();
      emblaInstance = null;
    }
  });

  // Re-initialize after view transitions
  document.addEventListener("astro:page-load", () => {
    initSlider();
  });
</script>
