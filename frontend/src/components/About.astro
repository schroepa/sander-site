---
import type { AboutData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
  data: AboutData;
}

const { data } = Astro.props;

// Resolve background image path (served from Grav pages media)
const bgVideo = data.background_video
  ? `${GRAV_MEDIA_BASE}/${data.background_video.split('/').pop()}`
  : null;

const bgImage = !bgVideo && data.background_image
  ? `${GRAV_MEDIA_BASE}/${data.background_image.split('/').pop()}`
  : null;

const hasOverlay =
  data.background_overlay !== false &&
  data.background_overlay !== 0 &&
  data.background_overlay !== "0";

// Resolve the right-column image
const sideImage = data.image ? `${GRAV_MEDIA_BASE}/${data.image.split('/').pop()}` : null;

// Resolve optional video thumbnail (shown on the play overlay before user clicks play)
const videoThumbnail = data.video_thumbnail
  ? `${GRAV_MEDIA_BASE}/${data.video_thumbnail.split('/').pop()}`
  : null;
---

<section class="about">
  {/* Background layer */}
  {
    (bgVideo || bgImage) && (
      <div class="about__bg" aria-hidden="true">
        {bgVideo ? (
          <video class="about__bg-img" src={bgVideo} autoplay muted loop playsinline preload="none" />
        ) : (
          <img class="about__bg-img" src={bgImage!} alt="" loading="lazy" />
        )}
        {hasOverlay && <div class="about__bg-overlay" />}
      </div>
    )
  }

  <div class="about__inner">
    {/* Left column: text */}
    <div class="about__text">
      {data.headline && <h2 class="about__headline">{data.headline}</h2>}
      {
        data.body && (
          <div class="about__body markdown-content" set:html={data.body} />
        )
      }
    </div>

    {/* Right column: video */}
    <div class="about__video-wrap">
      <div class="about__video-inner">
        <div id="about-yt-player"></div>
      </div>

      <!-- Play overlay: visible before user starts the video -->
      <button
        id="about-play-overlay"
        class="about__play-overlay"
        aria-label="Video abspielen"
        style={videoThumbnail ? `background-image: url('${videoThumbnail}'); background-size: cover; background-position: center;` : undefined}
      >
        <div class="about__play-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
        </div>
      </button>

      <!-- Controls: hidden until video starts -->
      <div class="about__controls" id="about-controls" style="display: none;">
        <button id="about-pause-btn" class="about__ctrl-btn" aria-label="Pause">
          <svg id="icon-pause" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="4" width="4" height="16"></rect>
            <rect x="14" y="4" width="4" height="16"></rect>
          </svg>
          <svg id="icon-play-small" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
        </button>
        <button id="about-mute-btn" class="about__ctrl-btn" aria-label="Ton an/aus">
          <svg id="icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
          </svg>
          <svg id="icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
          </svg>
        </button>
        <button id="about-fs-btn" class="about__ctrl-btn" aria-label="Vollbild">
          <svg id="icon-fs-enter" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 3 21 3 21 9"></polyline>
            <polyline points="9 21 3 21 3 15"></polyline>
            <line x1="21" y1="3" x2="14" y2="10"></line>
            <line x1="3" y1="21" x2="10" y2="14"></line>
          </svg>
          <svg id="icon-fs-exit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
            <polyline points="4 14 10 14 10 20"></polyline>
            <polyline points="20 10 14 10 14 4"></polyline>
            <line x1="10" y1="14" x2="3" y2="21"></line>
            <line x1="21" y1="3" x2="14" y2="10"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  {/* Full-width quote bar */}
  {
    data.quote && (
      <div class="about__quote-bar">
        <blockquote class="about__quote">
          <p class="about__quote-text">„{data.quote}"</p>
          {data.quote_author && (
            <cite class="about__quote-author">— {data.quote_author}</cite>
          )}
        </blockquote>
      </div>
    )
  }
</section>

<script is:inline>
  window.onYouTubeIframeAPIReady = function () {
    window.aboutVideoPlayer = new YT.Player("about-yt-player", {
      videoId: "FU8jBcRjik4",
      host: "https://www.youtube-nocookie.com",
      playerVars: {
        playsinline: 1,
        controls: 1,
        disablekb: 1,
        fs: 1,
        rel: 0,
        mute: 1,
        autoplay: 0,
        start: 402, // 6:42
        end: 593,   // 9:53
      },
      events: {
        onStateChange: function (event) {
          if (event.data === YT.PlayerState.ENDED) {
            event.target.seekTo(402);
            event.target.playVideo();
          }
          var iconPause = document.getElementById("icon-pause");
          var iconPlaySmall = document.getElementById("icon-play-small");
          if (iconPause && iconPlaySmall) {
            var playing = event.data === YT.PlayerState.PLAYING;
            iconPause.style.display = playing ? "block" : "none";
            iconPlaySmall.style.display = playing ? "none" : "block";
          }
        },
      },
    });
  };

  (function () {
    if (!window.YT) {
      var tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      var firstScriptTag = document.getElementsByTagName("script")[0];
      if (firstScriptTag) {
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
      } else {
        document.head.appendChild(tag);
      }
    } else if (window.YT && window.YT.Player) {
      window.onYouTubeIframeAPIReady();
    }

    // Play overlay
    var overlay = document.getElementById("about-play-overlay");
    var controls = document.getElementById("about-controls");

    if (overlay) {
      overlay.addEventListener("click", function () {
        overlay.style.opacity = "0";
        overlay.style.pointerEvents = "none";
        setTimeout(function () { overlay.style.display = "none"; }, 300);
        if (controls) controls.style.display = "flex";
        if (window.aboutVideoPlayer && typeof window.aboutVideoPlayer.playVideo === "function") {
          window.aboutVideoPlayer.playVideo();
        }
      });
    }

    // Mute toggle
    var muteBtn = document.getElementById("about-mute-btn");
    var iconMuted = document.getElementById("icon-muted");
    var iconUnmuted = document.getElementById("icon-unmuted");

    if (muteBtn) {
      muteBtn.addEventListener("click", function () {
        if (window.aboutVideoPlayer && typeof window.aboutVideoPlayer.isMuted === "function") {
          if (window.aboutVideoPlayer.isMuted()) {
            window.aboutVideoPlayer.unMute();
            iconMuted.style.display = "none";
            iconUnmuted.style.display = "block";
          } else {
            window.aboutVideoPlayer.mute();
            iconMuted.style.display = "block";
            iconUnmuted.style.display = "none";
          }
        }
      });
    }

    // Pause/play toggle
    var pauseBtn = document.getElementById("about-pause-btn");

    if (pauseBtn) {
      pauseBtn.addEventListener("click", function () {
        if (!window.aboutVideoPlayer) return;
        var state = window.aboutVideoPlayer.getPlayerState();
        if (state === YT.PlayerState.PLAYING) {
          window.aboutVideoPlayer.pauseVideo();
        } else {
          window.aboutVideoPlayer.playVideo();
        }
      });
    }

    // Fullscreen toggle
    var fsBtn = document.getElementById("about-fs-btn");
    var iconFsEnter = document.getElementById("icon-fs-enter");
    var iconFsExit = document.getElementById("icon-fs-exit");

    function onFsChange() {
      var isFs = !!(document.fullscreenElement || document.webkitFullscreenElement);
      if (iconFsEnter) iconFsEnter.style.display = isFs ? "none" : "block";
      if (iconFsExit) iconFsExit.style.display = isFs ? "block" : "none";
      if (fsBtn) fsBtn.setAttribute("aria-label", isFs ? "Vollbild beenden" : "Vollbild");
    }

    document.addEventListener("fullscreenchange", onFsChange);
    document.addEventListener("webkitfullscreenchange", onFsChange);

    if (fsBtn) {
      fsBtn.addEventListener("click", function () {
        if (document.fullscreenElement || document.webkitFullscreenElement) {
          if (document.exitFullscreen) document.exitFullscreen();
          else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
        } else {
          var iframe = window.aboutVideoPlayer && window.aboutVideoPlayer.getIframe();
          if (!iframe) return;
          if (iframe.requestFullscreen) iframe.requestFullscreen();
          else if (iframe.webkitRequestFullscreen) iframe.webkitRequestFullscreen();
        }
      });
    }
  })();
</script>

<style>
  /* ─── Section ─── */
  .about {
    position: relative;
    overflow: hidden;
    padding: var(--space-1000) var(--space-800);
  }

  /* ─── Background ─── */
  .about__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .about__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-width: none;
  }

  .about__bg-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-background-overlay);
  }

  /* ─── Inner layout: two columns ─── */
  .about__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-800);
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ─── Text column ─── */
  .about__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
  }

  .about__overline {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-overline-lg);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .about__headline {
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: var(--text-h1);
    line-height: var(--leading-h1);
    color: var(--color-text-primary);
    margin: 0;
  }

  .about__body {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
    color: var(--color-text-secondary);
    letter-spacing: 0.3px;
  }

  .about__body :global(p) {
    margin-top: 0;
    margin-bottom: var(--space-200);
  }

  .about__body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* ─── Video Column ─── */
  .about__video-wrap {
    position: relative;
    border-radius: var(--radius-300);
    overflow: hidden;
    border: 1px solid var(--color-stroke-tertiary);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
    aspect-ratio: 4 / 3;
    background-color: #000;
  }

  .about__video-inner {
    position: absolute;
    top: -25%;
    left: -25%;
    width: 150%;
    height: 150%;
    pointer-events: none;
  }

  .about__video-inner :global(iframe) {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ─── Play overlay ─── */
  .about__play-overlay {
    position: absolute;
    inset: 0;
    z-index: 20;
    background-color: rgba(0, 0, 0, 0.35);
    background-size: cover;
    background-position: center;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  /* dark tint on top of the thumbnail so the play button stays readable */
  .about__play-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    pointer-events: none;
  }

  .about__play-icon {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 2px solid rgba(255, 255, 255, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .about__play-overlay:hover .about__play-icon {
    transform: scale(1.1);
    background: rgba(255, 255, 255, 0.2);
  }

  .about__play-icon svg {
    width: 28px;
    height: 28px;
    margin-left: 4px; /* optical center for play triangle */
  }

  /* ─── Controls (mute + fullscreen) ─── */
  .about__controls {
    position: absolute;
    bottom: var(--space-400);
    right: var(--space-400);
    z-index: 10;
    display: flex;
    gap: var(--space-200);
    align-items: center;
  }

  .about__ctrl-btn {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text-primary, #fff);
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .about__ctrl-btn:hover {
    background: rgba(0, 0, 0, 0.6);
    transform: scale(1.05);
  }

  .about__ctrl-btn svg {
    width: 24px;
    height: 24px;
  }

  /* ─── Quote Bar ─── */
  .about__quote-bar {
    position: relative;
    margin-left: calc(-1 * var(--space-800));
    margin-right: calc(-1 * var(--space-800));
    padding: var(--space-800) var(--space-800);
    text-align: center;
  }

  .about__quote {
    margin: 0 auto;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
  }

  .about__quote-text {
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: var(--text-h2);
    line-height: var(--leading-h2);
    color: var(--color-text-primary);
    margin: 0;
    font-style: italic;
  }

  .about__quote-author {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-overline-lg);
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-style: normal;
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: var(--space-500);
    }

    .about__video-wrap {
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: var(--space-1000) var(--space-200);
    }

    .about__headline {
      font-size: var(--text-h2);
      line-height: var(--leading-h2);
    }

    .about__body {
      font-size: var(--text-body-md);
      line-height: var(--leading-body-md);
    }

    .about__quote-bar {
      margin-left: calc(-1 * var(--space-200));
      margin-right: calc(-1 * var(--space-200));
      padding: var(--space-600) var(--space-200);
    }

    .about__quote-text {
      font-size: var(--text-h3);
      line-height: var(--leading-h3);
    }
  }
</style>
