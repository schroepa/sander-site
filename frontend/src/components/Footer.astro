---
import { getSiteConfig } from "../lib/grav";
import imgVector from "../assets/footer/2063c9c4f8827d6f757c89b6eb502ed5ac3df06b.svg?url";
import imgVector1 from "../assets/footer/2dac724f42816a9dad1cd4cbb69446a88edfb89f.svg?url";
import imgVector2 from "../assets/footer/53fbd75ef7e76b79032bf1f6373ba4519d73858b.svg?url";
import imgVector3 from "../assets/footer/c05db558dab882d047f4f68c6a75efee85a16edf.svg?url";
import imgVector4 from "../assets/footer/d884b431a528cafb757a45c166afe14479577c0e.svg?url";

const siteConfig = getSiteConfig();
const footerData = siteConfig?.footer || {
  menus: [],
  socials: [],
  copyright: "",
};

const defaultIcons: Record<string, string> = {
  LinkedIn: imgVector,
  Twitter: imgVector1,
  Facebook: imgVector2,
  Instagram: imgVector3,
  YouTube: imgVector4,
};

function getSocialIcon(social: any, index: number) {
  if (social.icon) return `/user/themes/grav/assets/${social.icon}`;
  return (
    defaultIcons[social.platform] ||
    defaultIcons[Object.keys(defaultIcons)[index % 5]]
  );
}
---

<footer
  class="bg-(--color-background-primary) flex flex-col items-center pt-4 px-4 sm:px-8 md:px-16 relative w-full"
>
  <div
    class="border-(--color-stroke-secondary) border-solid border-t flex flex-col gap-10 items-center pb-20 pt-10 relative w-full max-w-7xl"
  >
    <div
      class="flex flex-wrap gap-2 items-center justify-center relative w-full"
    >
      {
        footerData.menus?.map((menu) => (
          <a
            href={menu.link}
            class="flex gap-2 items-center justify-center px-4 py-3 relative rounded-xl hover:bg-(--color-background-secondary) transition-colors"
          >
            <p class="font-geist font-medium leading-6 relative text-(--color-text-secondary) text-base tracking-[0.3px]">
              {menu.label}
            </p>
          </a>
        ))
      }
    </div>

    <div class="flex gap-6 items-start relative shrink-0">
      {
        footerData.socials?.map((social, idx) => (
          <a
            href={social.link}
            target="_blank"
            rel="noopener noreferrer"
            class="relative shrink-0 size-6 hover:opacity-80 transition-opacity"
            aria-label={social.platform}
          >
            <img
              src={getSocialIcon(social, idx)}
              alt={social.platform}
              class="absolute block w-full h-full object-contain"
            />
          </a>
        ))
      }
    </div>

    <p
      class="font-geist font-medium leading-[14.5px] relative text-(--color-text-tertiary) text-xs tracking-[0.4px]"
    >
      {footerData.copyright}
    </p>
  </div>
</footer>
