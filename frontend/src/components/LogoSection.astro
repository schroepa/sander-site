---
import type { LogoSectionData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
    data: LogoSectionData;
}

const { data } = Astro.props;
const logos = data.items ?? [];
const logoColor = data.logo_color || "#f1eef0";

// JS on the client will duplicate as needed — render one copy here
const allLogos = logos;

const bgVideo = data.background_video
    ? `${GRAV_MEDIA_BASE}/${data.background_video.split('/').pop()}`
    : null;

const bgImage = !bgVideo && data.background_image
    ? `${GRAV_MEDIA_BASE}/${data.background_image.split('/').pop()}`
    : null;

const hasOverlay =
    data.background_overlay !== false &&
    data.background_overlay !== 0 &&
    data.background_overlay !== "0";
---

<section class="logos">
    {(bgVideo || bgImage) && (
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            {bgVideo && (
                <video src={bgVideo} autoplay muted loop playsinline preload="none" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {bgImage && (
                <img src={bgImage} alt="" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {hasOverlay && (
                <div class="absolute inset-0" style="background-color: var(--color-background-overlay);" />
            )}
        </div>
    )}
    {data.headline && <h2 class="logos__headline">{data.headline}</h2>}

    <div class="logos__track-wrapper">
        <div class="logos__track" id="logos-track">
            {
                allLogos.map((logo) => {
                    const src = logo.image
                        ? `${GRAV_MEDIA_BASE}/${logo.image}`
                        : null;
                    return src ? (
                        <div class="logos__item" title={logo.name}>
                            <div
                                class="logos__icon"
                                style={`
                -webkit-mask-image: url('${src}');
                mask-image: url('${src}');
                background-color: ${logoColor};
              `}
                                role="img"
                                aria-label={logo.name}
                            />
                        </div>
                    ) : null;
                })
            }
        </div>
    </div>
</section>

<script>
    const track = document.getElementById("logos-track");
    if (track && track.children.length > 0) {
        const originalItems = Array.from(track.children);

        // Step 1: clone original set until track is at least 2× viewport wide
        while (track.scrollWidth < window.innerWidth * 2) {
            originalItems.forEach((item) =>
                track.appendChild(item.cloneNode(true)),
            );
        }

        // Step 2: duplicate the full track → two identical halves, -50% loops perfectly
        Array.from(track.children).forEach((item) =>
            track.appendChild(item.cloneNode(true)),
        );

        // Step 3: set duration based on pixel speed (80px/s) so it's always consistent
        const halfWidth = track.scrollWidth / 2;
        const pxPerSecond = 50;
        const duration = halfWidth / pxPerSecond;
        track.style.setProperty("--marquee-duration", `${duration}s`);
    }
</script>

<style>
    /* ─── Section ─── */
    .logos {
        position: relative;
        overflow: hidden;
        background-color: var(--color-background-elevation2);
        padding: var(--space-800) var(--space-400);
        border-top: 1px solid var(--color-stroke-tertiary);
        border-bottom: 1px solid var(--color-stroke-tertiary);
    }

    .logos__headline {
        position: relative;
        z-index: 10;
        font-family: var(--font-heading);
        font-weight: var(--weight-bold);
        font-size: var(--text-h3);
        line-height: var(--leading-h3);
        color: var(--color-text-primary);
        text-align: center;
        margin: 0 0 var(--space-600);
    }

    /* ─── Marquee wrapper ─── */
    .logos__track-wrapper {
        position: relative;
        z-index: 10;
        padding: 0 var(--space-500) var(--space-1000);
        width: 100%;
        overflow: hidden;
        /* Desktop: 200px Fade */
        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0,
            black 200px,
            black calc(100% - 200px),
            transparent 100%
        );
        mask-image: linear-gradient(
            to right,
            transparent 0,
            black 200px,
            black calc(100% - 200px),
            transparent 100%
        );
    }

    /* ─── Scrolling track ─── */
    .logos__track {
        display: flex;
        align-items: center;
        width: max-content;
        animation: marquee var(--marquee-duration, 60s) linear infinite;
    }

    .logos__track:hover {
        animation-play-state: paused;
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    /* ─── Single logo item ─── */
    .logos__item {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        padding-right: var(--space-800);
    }

    /* ─── Icon via CSS mask (allows color override) ─── */
    .logos__icon {
        width: 120px;
        height: 48px;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        transition: opacity 0.3s ease;
    }

    .logos__item:hover .logos__icon {
        opacity: 0.7;
    }

    /* ─── Responsive ─── */
    @media (max-width: 1024px) {
        .logos__track-wrapper {
            -webkit-mask-image: linear-gradient(
                to right,
                transparent 0,
                black 120px,
                black calc(100% - 120px),
                transparent 100%
            );
            mask-image: linear-gradient(
                to right,
                transparent 0,
                black 120px,
                black calc(100% - 120px),
                transparent 100%
            );
        }
    }

    @media (max-width: 768px) {
        .logos__track-wrapper {
            -webkit-mask-image: linear-gradient(
                to right,
                transparent 0%,
                black 10%,
                black 90%,
                transparent 100%
            );
            mask-image: linear-gradient(
                to right,
                transparent 0%,
                black 10%,
                black 90%,
                transparent 100%
            );
        }

        .logos {
            padding: var(--space-600) var(--space-200);
        }

        .logos__headline {
            font-size: var(--text-h4);
            line-height: var(--leading-h4);
            margin-bottom: var(--space-400);
        }

        .logos__icon {
            width: 80px;
            height: 36px;
        }

        .logos__item {
            height: 36px;
        }

        .logos__item {
            padding-right: var(--space-600);
        }
    }
</style>
