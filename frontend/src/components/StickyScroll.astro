---
import type { StickyScrollData } from "../lib/grav";
import { marked } from "marked";

interface Props {
  data: StickyScrollData;
}

const { data } = Astro.props;

function renderMarkdown(text: string | undefined) {
  return text ? (marked.parse(text) as string) : "";
}
---

<section class="sticky-scroll-section">
  <div class="sticky-scroll-container">
    {/* Left Column: Fixed Content */}
    <div class="content-left">
      <div class="header-content">
        {data && <p class="section-overline">{data.overline}</p>}
        {data.headline && <h2 class="headline">{data.headline}</h2>}
        {
          data.subline && (
            <div
              class="subline prose prose-invert"
              set:html={renderMarkdown(data.subline)}
            />
          )
        }
      </div>

      {/* Dropdown / Active Item Indicator */}
      {
        data.items && data.items.length > 0 && (
          <div class="dropdown-wrapper">
            <button class="dropdown-trigger" id="sticky-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Kategorie wählen">
              <span id="sticky-active-label">
                {data.items[0].dropdown_label || "Select..."}
              </span>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M6 9L12 15L18 9"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>

            <ul class="dropdown-menu" id="sticky-dropdown-menu" role="listbox" aria-labelledby="sticky-dropdown-trigger">
              {data.items.map((item, index) => (
                <li class="dropdown-item" data-index={index} role="option" aria-selected="false" tabindex="-1">
                  {item.dropdown_label}
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    {/* Right Column: Scrollable Cards */}
    <div class="content-right" id="sticky-scroll-container">
      <div class="scroll-pad top-pad"></div>

      {
        [
          ...(data.items || []),
          ...(data.items || []),
          ...(data.items || []),
        ].map((item, mappedIndex) => {
          const index = mappedIndex % (data.items?.length || 1);
          return (
            <div
              class="card"
              data-index={index}
              data-mapped-index={mappedIndex}
            >
              <div class="card-header">
                {item.title && <h3 class="card-title">{item.title}</h3>}
                {item.subtitle && <p class="card-subtitle">{item.subtitle}</p>}
              </div>

              <div class="card-body">
                {item.body_bold && (
                  <div
                    class="body-bold prose prose-invert"
                    set:html={item.body_bold}
                  />
                )}
                {item.body_text && (
                  <div
                    class="body-text prose prose-invert"
                    set:html={item.body_text}
                  />
                )}
              </div>
            </div>
          );
        })
      }

      <div class="scroll-pad bottom-pad"></div>
    </div>
  </div>

  {/* Fade Outlays (gradient overlays) */}
  <div class="fade-top"></div>
  <div class="fade-bottom"></div>
</section>

<style>
  .sticky-scroll-section {
    position: relative;
    padding: var(--space-1000) var(--space-800);
    width: 100%;
    margin-top: 100px;
    background-image: url("/assets/sander-manufaktur-image.png");
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .sticky-scroll-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-background-overlay);
    z-index: 0;
    pointer-events: none;
  }

  .sticky-scroll-container {
    position: relative;
    z-index: 1;
  }

  /* Dropdown muss über den Gradient-Fades liegen (z-index 10).
     Da das dropdown-menu im Stacking-Context des Containers gefangen ist,
     heben wir den gesamten Container über die Fades sobald das Dropdown offen ist. */
  .sticky-scroll-container:has(.dropdown-wrapper.open) {
    z-index: 20;
  }

  .fade-top,
  .fade-bottom {
    z-index: 11;
  }

  /* Fade overlays to blend the scrolling container */
  .fade-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(
      to bottom,
      var(--color-bg-app) 20%,
      transparent
    );
    z-index: 10;
    pointer-events: none;
  }

  .fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(to top, var(--color-bg-app) 20%, transparent);
    z-index: 10;
    pointer-events: none;
  }

  .sticky-scroll-container {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-500);
    position: relative;
    /* Height matches approximately the scroll container height */
    height: 715px;
  }

  /* Left Side */
  .content-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-500);
    height: 100%;
    position: relative;
    z-index: 2;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-100);
  }

  .section-overline {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
    color: var(--color-text-tertiary);
    letter-spacing: 0.5px;
    margin: 0;
  }

  .headline {
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: var(--text-h1);
    line-height: var(--leading-h1);
    color: var(--color-text-primary);
  }

  .subline {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
    color: var(--color-text-secondary);
    letter-spacing: 0.5px;
  }

  /* Dropdown styling */
  .dropdown-wrapper {
    position: relative;
    width: 100%;
    max-width: 343px;
  }

  .dropdown-trigger {
    background-color: var(--color-bg-card);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-rounded);
    padding: var(--space-200) var(--space-300);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .dropdown-trigger:hover {
    border-color: var(--color-text-tertiary);
  }

  .dropdown-trigger span {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-body-sm);
    color: var(--color-text-primary);
    letter-spacing: 0.25px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    width: 100%;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-200);
    padding: var(--space-100) 0;
    list-style: none;
    margin: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
    transition: all 0.2s ease;
    z-index: 20;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .dropdown-wrapper.open .dropdown-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .dropdown-wrapper.open .dropdown-trigger svg {
    transform: rotate(180deg);
  }

  .dropdown-item {
    padding: var(--space-150) var(--space-300);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .dropdown-item:hover,
  .dropdown-item.active {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  .content-right {
    height: 715px;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
    /* Hide scrollbar */
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .content-right::-webkit-scrollbar {
    display: none;
  }

  /* Scroll pads to center the first and last items */
  .scroll-pad {
    flex-shrink: 0;
    height: calc(50% - 180px); /* Approx half height minus half card height */
  }

  /* Cards */
  .card {
    background-color: var(--color-bg-card);
    border-radius: var(--radius-300);
    padding: var(--space-500) var(--space-800);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-200);
    height: 361px;
    flex-shrink: 0;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    box-shadow:
      0px 24px 40px 0px rgba(37, 28, 33, 0.08),
      0px 6px 16px 0px rgba(37, 28, 33, 0.04);
    transition:
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    transform: scale(0.9);
    opacity: 0.4;
  }

  .card.active {
    transform: scale(1);
    opacity: 1;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-050);
  }

  .card-title {
    font-family: var(--font-heading);
    font-weight: var(--weight-extra-bold);
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    color: var(--color-text-primary);
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-h4);
    line-height: var(--leading-h4);
    color: var(--color-text-secondary);
    letter-spacing: 0.15px;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-200);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-body-md);
    color: var(--color-text-secondary);
  }

  .body-bold {
    font-weight: var(--weight-bold);
  }

  .body-text {
    font-weight: var(--weight-medium);
    letter-spacing: 0.5px;
  }

  @media (max-width: 1024px) {
    .sticky-scroll-container {
      grid-template-columns: 1fr;
      height: auto;
      gap: 60px;
    }

    .content-right {
      height: 500px;
    }

    .scroll-pad {
      height: 50px;
    }

    .fade-top,
    .fade-bottom {
      display: none;
    }

    .dropdown-wrapper {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .sticky-scroll-section {
      padding: var(--space-800) var(--space-200);
      margin-top: 40px;
    }
  }

  @media (max-width: 640px) {
    .card {
      padding: var(--space-300) var(--space-200);
      height: auto;
      min-height: 250px;
    }
  }
</style>

<script>
  function initStickyScroll() {
    const section = document.querySelector(".sticky-scroll-section");
    if (!section) return;

    const dropdownWrapper = document.querySelector(".dropdown-wrapper");
    const dropdownTrigger = document.getElementById("sticky-dropdown-trigger");
    const dropdownItems = document.querySelectorAll(".dropdown-item");
    const activeLabel = document.getElementById("sticky-active-label");
    const scrollContainer = document.getElementById("sticky-scroll-container");
    const cards = document.querySelectorAll(".card");

    if (!scrollContainer || cards.length === 0) return;

    // Toggle Dropdown
    if (dropdownTrigger && dropdownWrapper) {
      dropdownTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = dropdownWrapper.classList.toggle("open");
        dropdownTrigger.setAttribute("aria-expanded", String(isOpen));
      });

      document.addEventListener("click", () => {
        dropdownWrapper.classList.remove("open");
        dropdownTrigger.setAttribute("aria-expanded", "false");
      });
    }

    // INFINITE SCROLL LOGIC
    const uniqueCardsCount = cards.length / 3;
    const setHeight =
      (cards[uniqueCardsCount] as HTMLElement).offsetTop -
      (cards[0] as HTMLElement).offsetTop;

    function getSnapPosition(card: HTMLElement) {
      if (!card) return 0;
      return (
        card.offsetTop -
        scrollContainer!.clientHeight / 2 +
        card.clientHeight / 2
      );
    }

    function setActiveCard(activeCard: HTMLElement) {
      cards.forEach((c) => c.classList.remove("active"));
      activeCard.classList.add("active");
    }

    // Set initial scroll to the first element of the middle set
    const middleFirstCard = cards[uniqueCardsCount] as HTMLElement;
    if (middleFirstCard) {
      scrollContainer.style.scrollSnapType = "none";
      scrollContainer.scrollTop = getSnapPosition(middleFirstCard);
      setActiveCard(middleFirstCard);
      setTimeout(() => {
        if (scrollContainer)
          scrollContainer.style.scrollSnapType = "y mandatory";
      }, 50);
    }

    // Helper: find card closest to center and mark it active
    function updateActiveCardByCenter() {
      const center = scrollContainer!.scrollTop + scrollContainer!.clientHeight / 2;
      let closest: HTMLElement | null = null;
      let minDist = Infinity;
      cards.forEach((c) => {
        const el = c as HTMLElement;
        const dist = Math.abs(el.offsetTop + el.clientHeight / 2 - center);
        if (dist < minDist) { minDist = dist; closest = el; }
      });
      if (closest) setActiveCard(closest);
    }

    // Teleport logic on scroll to create the illusion of infinite scrolling
    scrollContainer.addEventListener("scroll", () => {
      if (cards.length < 3) return;

      const snapCardN = getSnapPosition(cards[uniqueCardsCount] as HTMLElement);
      const snapCardNMinus1 = getSnapPosition(
        cards[uniqueCardsCount - 1] as HTMLElement,
      );
      // Midpoint between last item of first set and first item of middle set
      const minScroll = Math.floor((snapCardN + snapCardNMinus1) / 2);

      const snapCard2NMinus1 = getSnapPosition(
        cards[uniqueCardsCount * 2 - 1] as HTMLElement,
      );
      const snapCard2N = getSnapPosition(
        cards[uniqueCardsCount * 2] as HTMLElement,
      );
      // Midpoint between last item of middle set and first item of third set
      const maxScroll = Math.ceil((snapCard2NMinus1 + snapCard2N) / 2);

      function teleport(delta: number) {
        scrollContainer!.style.scrollSnapType = "none";
        scrollContainer!.scrollTop += delta;
        updateActiveCardByCenter();
        setTimeout(() => {
          scrollContainer!.style.scrollSnapType = "y mandatory";
        }, 0);
      }

      if (scrollContainer.scrollTop <= minScroll) {
        teleport(setHeight);
      } else if (scrollContainer.scrollTop >= maxScroll) {
        teleport(-setHeight);
      }
    });

    // Update active card after scroll snap has fully settled
    scrollContainer.addEventListener("scrollend", () => {
      updateActiveCardByCenter();
    });

    // Handle Dropdown Item Click
    dropdownItems.forEach((item) => {
      item.addEventListener("click", (e) => {
        const index = parseInt(
          (e.target as HTMLElement).dataset.index || "0",
          10,
        );
        // Scroll to the card residing in the middle set
        const targetCard = cards[index + uniqueCardsCount] as HTMLElement;

        // Update label
        if (activeLabel) {
          activeLabel.textContent = item.textContent || "";
        }

        // Scroll to card
        if (targetCard && scrollContainer) {
          scrollContainer.scrollTo({
            top: getSnapPosition(targetCard),
            behavior: "smooth",
          });
        }
      });
    });

    // ScrollSpy to update dropdown label when scrolling
    if (scrollContainer) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
              const card = entry.target as HTMLElement;
              const index = card.dataset.index;

              // Only update dropdown label – active card class is managed by scroll handler
              const matchingDropdownItem = document.querySelector(
                `.dropdown-item[data-index="${index}"]`,
              );

              if (activeLabel && matchingDropdownItem) {
                activeLabel.textContent =
                  matchingDropdownItem.textContent || "";

                dropdownItems.forEach((i) => i.classList.remove("active"));
                matchingDropdownItem.classList.add("active");
              }
            }
          });
        },
        {
          root: scrollContainer,
          threshold: 0.6,
        },
      );

      cards.forEach((card) => observer.observe(card));
    }
  }

  // Initialize on full page load and Astro view transitions
  document.addEventListener("astro:page-load", initStickyScroll);
  document.addEventListener("DOMContentLoaded", initStickyScroll);
</script>
