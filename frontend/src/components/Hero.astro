---
import type { HeroData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";
import SanderLogoHero from "./SanderLogoHero.astro";

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;

const headlineScale = hero.headline_scale ?? 1;
const sublineScale = hero.subline_scale ?? 1;
const gapSpacing = hero.headline_subline_spacing ?? 1.5;

const bgVideo = hero.background_video
  ? `${GRAV_MEDIA_BASE}/${hero.background_video.split("/").pop()}`
  : null;
const bgImage = !bgVideo && hero.background_image
  ? `${GRAV_MEDIA_BASE}/${hero.background_image.split("/").pop()}`
  : null;
const hasOverlay =
  (bgVideo || bgImage) &&
  hero.background_overlay !== false &&
  hero.background_overlay !== 0 &&
  hero.background_overlay !== "0";
const isDesaturated =
  hero.background_desaturate === true ||
  hero.background_desaturate === 1 ||
  hero.background_desaturate === "1";
---

<section
  class="hero-section relative min-h-screen flex items-center justify-center"
  style="background-color: var(--color-bg-app); color: var(--color-text-primary);"
>
  {/* Background: Vanilla CSS/JS – kein WebGL, kein Canvas */}
  <div class="hero__bg" aria-hidden="true">
    {/* Optionaler Medien-Hintergrund: Video hat Vorrang vor Bild */}
    {bgVideo && (
      <video
        class={`hero__media${isDesaturated ? " hero__media--desaturate" : ""}`}
        src={bgVideo}
        autoplay
        muted
        loop
        playsinline
      />
    )}
    {bgImage && (
      <img
        class={`hero__media${isDesaturated ? " hero__media--desaturate" : ""}`}
        src={bgImage}
        alt=""
      />
    )}
    {hasOverlay && <div class="hero__media-overlay" />}

    <div class="hero__perspective">
      <div class="hero__deco-wrap">
        <span class="hero__deco-text hero__deco-text--dim">SMART<br />CATERING</span>
        <span class="hero__deco-text hero__deco-text--lit">SMART<br />CATERING</span>
        <span class="hero__deco-text hero__deco-text--shadow">SMART<br />CATERING</span>
      </div>
    </div>
    <div class="hero__spotlight"></div>
  </div>

  {/* Foreground content */}
  <div
    class="relative z-10 text-center max-w-3xl px-6 pointer-events-none"
    style={`display: flex; flex-direction: column; gap: ${gapSpacing}rem;`}
  >
    <h1
      class="font-black tracking-tight leading-tight"
      style={`font-family: var(--font-heading); font-size: calc(var(--text-h1) * ${headlineScale}); line-height: var(--leading-h1); font-weight: var(--weight-black);`}
    >
      <Fragment set:html={hero.headline} />
    </h1>
    {
      hero.subline && (
        <p
          style={`font-family: var(--font-body); font-size: calc(var(--text-body-lg) * ${sublineScale}); line-height: var(--leading-body-lg); color: var(--color-text-secondary);`}
        >
          {hero.subline}
        </p>
      )
    }
    {
      (hero.show_cta === true ||
        hero.show_cta === 1 ||
        hero.show_cta === "1") &&
        hero.cta_text && (
          <a
            href={hero.cta_link ?? "#"}
            class="pointer-events-auto inline-block transition-opacity duration-200 hover:opacity-90"
            style={`
                        margin-top: var(--space-200);
                        padding: var(--space-150) var(--space-500);
                        background-color: var(--color-btn-primary-bg);
                        color: var(--color-btn-primary-text);
                        font-family: var(--font-action);
                        font-size: var(--text-action-lg);
                        font-weight: var(--weight-medium);
                        border-radius: var(--radius-rounded);
                        box-shadow: var(--shadow-m);
                    `}
          >
            {hero.cta_text}
          </a>
        )
    }
  </div>

  {/* Logo at the bottom center */}
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 z-20 pointer-events-none pb-6 md:pb-10 w-full px-6 flex justify-center"
  >
    <SanderLogoHero />
  </div>
</section>

<script is:inline>
  (function () {
    var section = document.querySelector(".hero-section");
    var decoWrap = section && section.querySelector(".hero__deco-wrap");
    var spotlight = section && section.querySelector(".hero__spotlight");
    var litText = section && section.querySelector(".hero__deco-text--lit");
    if (!section || !decoWrap || !spotlight || !litText) return;

    var targetX = 0.5,
      targetY = 0.5;
    var currentX = 0.5,
      currentY = 0.5;
    var rafId = null;

    function lerp(a, b, t) {
      return a + (b - a) * t;
    }

    function tick() {
      currentX = lerp(currentX, targetX, 0.06);
      currentY = lerp(currentY, targetY, 0.06);

      var rx = (currentY - 0.5) * 10;
      var ry = (currentX - 0.5) * -10;
      decoWrap.style.transform =
        "rotateX(" + rx + "deg) rotateY(" + ry + "deg)";

      spotlight.style.setProperty("--mx", currentX * 100 + "%");
      spotlight.style.setProperty("--my", currentY * 100 + "%");

      if (
        Math.abs(currentX - targetX) > 0.0005 ||
        Math.abs(currentY - targetY) > 0.0005
      ) {
        rafId = requestAnimationFrame(tick);
      } else {
        rafId = null;
      }
    }

    section.addEventListener("mousemove", function (e) {
      var rect = section.getBoundingClientRect();
      targetX = (e.clientX - rect.left) / rect.width;
      targetY = (e.clientY - rect.top) / rect.height;
      if (!rafId) rafId = requestAnimationFrame(tick);

      // Taschenlampe: Koordinaten relativ zum lit-Element selbst
      var litRect = litText.getBoundingClientRect();
      litText.style.setProperty("--lx", e.clientX - litRect.left + "px");
      litText.style.setProperty("--ly", e.clientY - litRect.top + "px");
    });

    section.addEventListener("mouseleave", function () {
      litText.style.setProperty("--lx", "-9999px");
      litText.style.setProperty("--ly", "-9999px");
    });
  })();
</script>

<style>
  .hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    background-color: var(--color-bg-app);
  }

  /* Optionaler Medien-Hintergrund (Video oder Bild) */
  .hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Overlay in der Markenfarbe aus den Design-Tokens */
  .hero__media-overlay {
    position: absolute;
    inset: 0;
    background-color: var(--color-bg-overlay);
  }

  /* Entsättigt das Medium – kombiniert mit dem farbigen Overlay
     ergibt sich automatisch der Aubergine-Ton der Marke */
  .hero__media--desaturate {
    filter: grayscale(100%);
  }

  /* Perspective-Container: gibt dem Kind-Element den 3D-Kontext */
  .hero__perspective {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 900px;
  }

  /* Wird per JS mit rotateX/rotateY animiert */
  .hero__deco-wrap {
    position: relative;
    width: 120%;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  .hero__deco-text {
    font-family: var(--font-heading);
    font-weight: 900;
    text-align: center;
    line-height: 0.81;
    user-select: none;
    pointer-events: none;
    font-size: 294px;
  }

  /* Ambient-Layer: immer sichtbar, gedimmt */
  .hero__deco-text--dim {
    color: #ad94a5;
    opacity: 0.3;
  }

  /* Lit-Layer: volle Helligkeit, nur im Taschenlampen-Radius sichtbar */
  .hero__deco-text--lit {
    position: absolute;
    color: #ad94a5;
    --lx: -9999px;
    --ly: -9999px;
    -webkit-mask-image: radial-gradient(
      circle 260px at var(--lx) var(--ly),
      black 0%,
      black 30%,
      transparent 70%
    );
    mask-image: radial-gradient(
      circle 260px at var(--lx) var(--ly),
      black 0%,
      black 30%,
      transparent 70%
    );
  }

  /* Shadow-Layer: liegt absolut über dem Dim-Text */
  .hero__deco-text--shadow {
    position: absolute;
    color: #745c6c;
    opacity: 0.16;
  }

  /* Tablet */
  @media (min-width: 576px) and (max-width: 991px) {
    .hero__deco-text {
      font-size: 365px;
    }
  }

  /* Mobile */
  @media (max-width: 575px) {
    .hero__deco-text {
      font-size: 179px;
    }
  }

  /* Spotlight folgt der Maus via CSS Custom Properties */
  .hero__spotlight {
    --mx: 50%;
    --my: 50%;
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 45% at var(--mx) var(--my),
      rgba(173, 148, 165, 0.1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
</style>
