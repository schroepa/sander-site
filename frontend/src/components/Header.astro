---
import { getSiteConfig } from "../lib/grav";

const pathname = new URL(Astro.request.url).pathname;

// Get SiteConfig and header config
const siteConfig = getSiteConfig();
const headerConfig = siteConfig?.header || {};

// Default values (fallback)
const logoUrl = headerConfig.logo || "/assets/39331785a20d94ae55004c6822ef1dd1b9eba1e7.svg";
const ctaText = headerConfig.cta_text || "Kontakt aufnehmen";
const ctaLink = headerConfig.cta_link || "/#kontakt";
const menus = headerConfig.menus || [
  {
    label: "Lösungen",
    link: "/#loesungen",
    submenus: [
      { label: "Lösung 1 (Platzhalter)", link: "/#loesung-1" },
      { label: "Lösung 2 (Platzhalter)", link: "/#loesung-2" },
      { label: "Lösung 3 (Platzhalter)", link: "/#loesung-3" },
      { label: "Lösung 4 (Platzhalter)", link: "/#loesung-4" },
    ],
  },
  {
    label: "Smart Catering",
    link: "/#smart-catering",
    submenus: [
      { label: "Vielfalt & Menülinien", link: "/#smart-1-1" },
      { label: "Sicher starten", link: "/#smart-1-2" },
      { label: "Digitalisierung", link: "/#smart-1-3" },
      { label: "Team & Personal", link: "/#smart-1-4" },
    ],
  },
  {
    label: "Die Frische Manufaktur",
    link: "/#frische-manufaktur",
  },
];

// Helper for dynamic href based on current page
function getHref(link: string) {
  if (pathname === "/" && link.startsWith("/#")) {
    return link.substring(1);
  }
  return link;
}

// Check active state
function isActive(link: string) {
  // Extract path from link (e.g. "/#loesungen" -> "/")
  const linkUrl = new URL(link, "http://localhost");
  const linkPath = linkUrl.pathname;
  if (linkPath === "/") {
    // If it's an anchor link on the home page, don't mark it active server-side
    // as that causes all anchor links to get the underline simultaneously.
    if (linkUrl.hash) return false;
    return pathname === linkPath;
  }
  return pathname.startsWith(linkPath);
}
---

<header
  class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-32px)] max-w-[1840px] z-50"
>
  <div
    class="backdrop-blur-[var(--blur-xl)] bg-[var(--color-background-elevation-glass2)] flex items-center justify-between px-6 py-3 rounded-[16px] shadow-sm"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0 flex items-center">
      <img src={logoUrl} alt="Sander Catering" class="w-8 h-8 object-contain" />
    </a>

    <!-- Navigation -->
    <nav class="hidden lg:flex flex-1 items-center justify-end gap-2 pr-4">
      {
        menus.map((item) => {
          const hasSubmenus = item.submenus && item.submenus.length > 0;
          const href = getHref(item.link);
          const activeClass = isActive(item.link)
            ? "text-[var(--color-text-primary)] border-b border-[var(--color-stroke-brand-bold)]"
            : "text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)]";

          if (hasSubmenus) {
            return (
              <div class="relative group">
                <a
                  href={href}
                  class={`flex items-center gap-1 px-2 py-2 transition-colors no-underline ${activeClass}`}
                >
                  <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]">
                    {item.label}
                  </span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4 opacity-70 group-hover:opacity-100 transition-transform duration-300 group-hover:rotate-180"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </a>
                <!-- Dropdown Menu -->
                <div class="absolute left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
                  <div class="bg-[var(--color-background-elevation-glass2)] backdrop-blur-[var(--blur-xl)] rounded-xl p-2 min-w-[200px] shadow-lg border border-[var(--color-stroke-tertiary)] flex flex-col gap-1">
                    {item.submenus!.map((sub) => (
                      <a
                        href={getHref(sub.link)}
                        class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px] whitespace-nowrap no-underline"
                      >
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            );
          }

          // Single Link without dropdown
          return (
            <a
              href={href}
              class={`flex items-center gap-1 px-2 py-2 transition-colors no-underline ${activeClass}`}
            >
              <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]">
                {item.label}
              </span>
            </a>
          );
        })
      }
    </nav>

    <!-- CTA Button & Mobile Menu Toggle -->
    <div class="shrink-0 flex items-center gap-4">
      <a
        href={getHref(ctaLink)}
        class="bg-[var(--color-components-button-primary-background-default)] hover:bg-[var(--color-components-button-primary-background-hover)] transition-colors text-[var(--color-components-button-primary-text-default)] flex items-center justify-center px-3 py-2 min-h-[32px] rounded-lg no-underline"
      >
        <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]"
          >{ctaText}</span
        >
      </a>
      <button
        id="mobile-menu-toggle"
        class="lg:hidden text-[var(--color-text-primary)] p-1 -mr-1"
        aria-label="Menu öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="4" x2="20" y1="12" y2="12"></line><line
            x1="4"
            x2="20"
            y1="6"
            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
        >
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
          ><line x1="18" x2="6" y1="6" y2="18"></line><line
            x1="6"
            x2="18"
            y1="6"
            y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden mt-2 backdrop-blur-[var(--blur-xl)] bg-[var(--color-background-elevation-glass2)] rounded-[16px] shadow-sm overflow-hidden"
  >
    <nav class="flex flex-col p-4 gap-1">
      {
        menus.map((item) => {
          const href = getHref(item.link);
          return (
            <a
              href={href}
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-3 rounded-lg text-sm font-medium transition-colors mobile-nav-link no-underline"
            >
              {item.label}
            </a>
          );
        })
      }
      <div class="border-t border-[var(--color-stroke-tertiary)] my-1"></div>
      <a
        href={getHref(ctaLink)}
        class="bg-[var(--color-components-button-primary-background-default)] hover:bg-[var(--color-components-button-primary-background-hover)] transition-colors text-[var(--color-components-button-primary-text-default)] flex items-center justify-center px-3 py-3 rounded-lg text-sm font-medium mobile-nav-link no-underline"
        >{ctaText}</a
      >
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    if (!toggle || !menu) return;

    // Remove any existing event listeners by cloning
    const newToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.parentNode?.replaceChild(newToggle, toggle);

    newToggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");

      if (isOpen) {
        menu.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        newToggle.setAttribute("aria-expanded", "false");
        newToggle.setAttribute("aria-label", "Menu öffnen");
      } else {
        menu.classList.remove("hidden");
        iconOpen?.classList.add("hidden");
        iconClose?.classList.remove("hidden");
        newToggle.setAttribute("aria-expanded", "true");
        newToggle.setAttribute("aria-label", "Menu schließen");
      }
    });

    // Close on nav-link click
    menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
      const newLink = link.cloneNode(true) as HTMLElement;
      link.parentNode?.replaceChild(newLink, link);
      
      newLink.addEventListener("click", () => {
        menu.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        newToggle.setAttribute("aria-expanded", "false");
        newToggle.setAttribute("aria-label", "Menu öffnen");
      });
    });
  }

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
