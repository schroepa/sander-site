---
const pathname = new URL(Astro.request.url).pathname;
const logoUrl = "/assets/39331785a20d94ae55004c6822ef1dd1b9eba1e7.svg";

function isActive(path: string) {
  if (path === "/") {
    return pathname === path;
  }
  return pathname.startsWith(path);
}
---

<header
  class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-80px)] max-w-[1840px] z-50"
>
  <div
    class="backdrop-blur-[var(--blur-xl)] bg-[var(--color-background-elevation-glass2)] flex items-center justify-between px-6 py-3 rounded-[16px] shadow-sm"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0 flex items-center">
      <img src={logoUrl} alt="Sander Catering" class="w-8 h-8 object-contain" />
    </a>

    <!-- Navigation -->
    <nav class="hidden lg:flex flex-1 items-center justify-end gap-2 pr-4">
      <!-- Dropdown 1: Lösungen -->
      <div class="relative group">
        <a
          href="#loesungen"
          class={`flex items-center gap-1 px-2 py-2 transition-colors ${isActive("/loesungen") ? "text-[var(--color-text-primary)] border-b border-[var(--color-stroke-brand-bold)]" : "text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)]"}`}
        >
          <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]"
            >Lösungen</span
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4 opacity-70 group-hover:opacity-100 transition-transform duration-300 group-hover:rotate-180"
            ><path d="m6 9 6 6 6-6"></path></svg
          >
        </a>
        <!-- Dropdown Menu -->
        <div
          class="absolute left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50"
        >
          <div
            class="bg-[var(--color-background-elevation-glass2)] backdrop-blur-[var(--blur-xl)] rounded-xl p-2 w-52 shadow-lg border border-[var(--color-stroke-tertiary)] flex flex-col gap-1"
          >
            <a
              href="#loesung-1"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Lösung 1 (Platzhalter)</a
            >
            <a
              href="#loesung-2"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Lösung 2 (Platzhalter)</a
            >
            <a
              href="#loesung-3"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Lösung 3 (Platzhalter)</a
            >
            <a
              href="#loesung-4"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Lösung 4 (Platzhalter)</a
            >
          </div>
        </div>
      </div>

      <!-- Dropdown 2: Smart Catering -->
      <div class="relative group">
        <a
          href="#smart-catering"
          class={`flex items-center gap-1 px-2 py-2 transition-colors ${isActive("/smart-catering") ? "text-[var(--color-text-primary)] border-b border-[var(--color-stroke-brand-bold)]" : "text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)]"}`}
        >
          <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]"
            >Smart Catering</span
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4 opacity-70 group-hover:opacity-100 transition-transform duration-300 group-hover:rotate-180"
            ><path d="m6 9 6 6 6-6"></path></svg
          >
        </a>
        <!-- Dropdown Menu -->
        <div
          class="absolute left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50"
        >
          <div
            class="bg-[var(--color-background-elevation-glass2)] backdrop-blur-[var(--blur-xl)] rounded-xl p-2 w-56 shadow-lg border border-[var(--color-stroke-tertiary)] flex flex-col gap-1"
          >
            <a
              href="#smart-1-1"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Vielfalt & Menülinien</a
            >
            <a
              href="#smart-1-2"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Sicher starten</a
            >
            <a
              href="#smart-1-3"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Digitalisierung</a
            >
            <a
              href="#smart-1-4"
              class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-2 rounded-lg text-[12px] leading-[16px] font-medium transition-colors tracking-[0.4px]"
              >Team & Personal</a
            >
          </div>
        </div>
      </div>

      <!-- Link without Dropdown: Die Frische Manufaktur -->
      <a
        href="#frische-manufaktur"
        class={`flex items-center gap-1 px-2 py-2 transition-colors ${isActive("/frische-manufaktur") ? "text-[var(--color-text-primary)] border-b border-[var(--color-stroke-brand-bold)]" : "text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)]"}`}
      >
        <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]"
          >Die Frische Manufaktur</span
        >
      </a>
    </nav>

    <!-- CTA Button & Mobile Menu Toggle -->
    <div class="shrink-0 flex items-center gap-4">
      <a
        href="#kontakt"
        class="bg-[var(--color-components-button-primary-background-default)] hover:bg-[var(--color-components-button-primary-background-hover)] transition-colors text-[var(--color-components-button-primary-text-default)] flex items-center justify-center px-3 py-2 min-h-[32px] rounded-lg"
      >
        <span class="font-medium text-[12px] leading-[16px] tracking-[0.4px]"
          >Kontakt aufnehmen</span
        >
      </a>
      <button
        id="mobile-menu-toggle"
        class="lg:hidden text-[var(--color-text-primary)] p-1 -mr-1"
        aria-label="Menu öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="4" x2="20" y1="12" y2="12"></line><line
            x1="4"
            x2="20"
            y1="6"
            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
        >
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
          ><line x1="18" x2="6" y1="6" y2="18"></line><line
            x1="6"
            x2="18"
            y1="6"
            y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden mt-2 backdrop-blur-[var(--blur-xl)] bg-[var(--color-background-elevation-glass2)] rounded-[16px] shadow-sm overflow-hidden"
  >
    <nav class="flex flex-col p-4 gap-1">
      <a
        href="#loesungen"
        class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-3 rounded-lg text-sm font-medium transition-colors mobile-nav-link"
        >Lösungen</a
      >
      <a
        href="#smart-catering"
        class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-3 rounded-lg text-sm font-medium transition-colors mobile-nav-link"
        >Smart Catering</a
      >
      <a
        href="#frische-manufaktur"
        class="text-[var(--color-text-primary)] hover:text-[var(--color-text-secondary)] hover:bg-[var(--color-stroke-primary)] px-3 py-3 rounded-lg text-sm font-medium transition-colors mobile-nav-link"
        >Die Frische Manufaktur</a
      >
      <div class="border-t border-[var(--color-stroke-tertiary)] my-1"></div>
      <a
        href="#kontakt"
        class="bg-[var(--color-components-button-primary-background-default)] hover:bg-[var(--color-components-button-primary-background-hover)] transition-colors text-[var(--color-components-button-primary-text-default)] flex items-center justify-center px-3 py-3 rounded-lg text-sm font-medium mobile-nav-link"
        >Kontakt aufnehmen</a
      >
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    if (!toggle || !menu) return;

    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");

      if (isOpen) {
        menu.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Menu öffnen");
      } else {
        menu.classList.remove("hidden");
        iconOpen?.classList.add("hidden");
        iconClose?.classList.remove("hidden");
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Menu schließen");
      }
    });

    // Close on nav-link click
    menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Menu öffnen");
      });
    });
  }

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
