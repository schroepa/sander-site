---
import type { AwardsData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
    data: AwardsData;
}

const { data } = Astro.props;
const items = data.items ?? [];
---

<section class="awards" id="auszeichnungen">
    <video
        class="awards__video"
        src="/assets/apple-ungraded.mp4"
        autoplay
        loop
        muted
        playsinline
        aria-hidden="true"
    ></video>
    <div class="awards__overlay" aria-hidden="true"></div>
    <div class="awards__inner">
        {data.headline && <h2 class="awards__headline">{data.headline}</h2>}

        {
            items.length > 0 && (
                <div class="awards__grid">
                    {items.map((item) => {
                        const imgSrc = item.image
                            ? `${GRAV_MEDIA_BASE}/${item.image.split('/').pop()}`
                            : null;
                        return (
                            <div class="awards__item">
                                <div class="awards__item-inner">
                                    <div class="awards__card-front">
                                        {imgSrc && (
                                            <div class="awards__badge">
                                                <img
                                                    class="awards__badge-img"
                                                    src={imgSrc}
                                                    alt={
                                                        item.label ??
                                                        "Auszeichnung"
                                                    }
                                                    loading="lazy"
                                                />
                                            </div>
                                        )}
                                        {item.label && (
                                            <p class="awards__label">
                                                {item.label}
                                            </p>
                                        )}
                                    </div>
                                    <div class="awards__card-back">
                                        {item.description ? (
                                            <p class="awards__description">
                                                {item.description}
                                            </p>
                                        ) : (
                                            item.label && (
                                                <p class="awards__description">
                                                    {item.label}
                                                </p>
                                            )
                                        )}
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            )
        }
    </div>
</section>

<style>
    /* ─── Section ─── */
    .awards {
        position: relative;
        overflow: hidden;
        padding: 0 var(--space-800) var(--space-1000);
    }

    /* ─── Video Background ─── */
    .awards__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
    }

    /* ─── Overlay ─── */
    .awards__overlay {
        position: absolute;
        inset: 0;
        background-color: var(--color-background-overlay);
        pointer-events: none;
    }

    /* ─── Inner ─── */
    .awards__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-800);
    }

    /* ─── Headline ─── */
    .awards__headline {
        font-family: var(--font-display);
        font-weight: var(--weight-bold);
        font-size: var(--text-display-sm);
        line-height: var(--leading-display-sm);
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--color-text-primary);
        text-align: center;
        margin: 0;
    }

    /* ─── Grid ─── */
    .awards__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-1000);
        width: 100%;
    }

    /* ─── Item ─── */
    .awards__item {
        position: relative;
        perspective: 1000px;
        width: 100%;
        height: 100%;
        min-height: 300px;
    }

    .awards__item-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        transform-style: preserve-3d;
    }

    .awards__item:hover .awards__item-inner,
    .awards__item:focus-within .awards__item-inner {
        transform: rotateY(180deg);
    }

    .awards__card-front,
    .awards__card-back {
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--space-100);
        background-color: var(--color-background-elevation2);
        padding: var(--space-300);
        border-radius: var(--radius-xl);
        text-align: center;
    }

    .awards__card-front {
        transform: rotateY(0deg);
        position: relative;
        z-index: 2;
    }

    .awards__card-back {
        position: absolute;
        top: 0;
        left: 0;
        transform: rotateY(180deg);
        background-color: var(--color-background-elevation1);
        border: 1px solid var(--color-border-subtle);
        padding: var(--space-400);
    }

    /* ─── Badge image ─── */
    .awards__badge {
        width: 200px;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .awards__badge-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    /* ─── Label ─── */
    .awards__label {
        font-family: var(--font-body);
        font-weight: var(--weight-medium);
        font-size: var(--text-body-lg);
        line-height: var(--leading-body-lg);
        letter-spacing: 0.5px;
        color: var(--color-text-primary);
        text-align: center;
        margin: 0;
    }

    /* ─── Description (Back) ─── */
    .awards__description {
        font-family: var(--font-body);
        font-weight: var(--weight-regular);
        font-size: var(--text-body-md);
        line-height: var(--leading-body-md);
        color: var(--color-text-secondary);
        margin: 0;
    }

    /* ─── Responsive ─── */
    @media (max-width: 768px) {
        .awards {
            padding: 0 var(--space-200) var(--space-1000);
        }

        .awards__headline {
            font-size: var(--text-h2);
            line-height: var(--leading-h2);
        }

        .awards__grid {
            grid-template-columns: 1fr;
            gap: var(--space-500);
        }

        .awards__badge {
            width: 150px;
            height: 150px;
        }
    }
</style>
