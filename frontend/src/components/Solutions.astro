---
import type { SolutionsData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
  data: SolutionsData;
}

const { data } = Astro.props;

const bgImage = data.background_image
  ? `${GRAV_MEDIA_BASE}/${data.background_image.split('/').pop()}`
  : null;

const hasOverlay =
  data.background_overlay !== false &&
  data.background_overlay !== 0 &&
  data.background_overlay !== "0";
---

<section class="solutions" id="loesungen">
  {bgImage && (
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <img src={bgImage} alt="" class="absolute inset-0 w-full h-full object-cover" />
      {hasOverlay && (
        <div class="absolute inset-0" style="background-color: var(--color-background-overlay);" />
      )}
    </div>
  )}
  <div class="solutions__headings">
    <h2 class="solutions__headline">{data.headline}</h2>
    {data.subline && <p class="solutions__subline">{data.subline}</p>}
  </div>

  <div class="solutions__container">
    {
      data.items.map((item, index) => (
        <div
          class="solutions__row"
          id={
            item.solution_title.toLowerCase().includes("frische")
              ? "frische-manufaktur"
              : `loesung-${index + 1}`
          }
        >
          {/* Challenge Card */}
          <div class="solutions__card solutions__card--challenge">
            <p class="solutions__card-title">{item.challenge_title}</p>
            <div
              class="solutions__card-text markdown-content"
              set:html={item.challenge_text}
            />
          </div>

          {/* Connector: start → circle-check → end */}
          <div class="solutions__connector">
            <picture class="solutions__connector-start">
              <source media="(max-width: 768px)" srcset="/assets/connector-start__mobile.svg" width="16" height="32" />
              <img src="/assets/connector-start__desktop.svg" width="72" height="16" alt="" aria-hidden="true" />
            </picture>
            <picture class="solutions__connector-circle">
              <source media="(max-width: 768px)" srcset="/assets/connector-circle-check__mobile.svg" width="24" height="24" />
              <img src="/assets/connector-circle-check__desktop.svg" width="40" height="40" alt="" />
            </picture>
            <picture class="solutions__connector-end">
              <source media="(max-width: 768px)" srcset="/assets/connector-end__mobile.svg" width="23" height="26" />
              <img src="/assets/connector-end__desktop.svg" width="66" height="23" alt="" aria-hidden="true" />
            </picture>
          </div>

          {/* Solution Card */}
          <div class="solutions__card solutions__card--solution">
            <p class="solutions__card-title">{item.solution_title}</p>
            <div
              class="solutions__card-text markdown-content"
              set:html={item.solution_text}
            />
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* ─── Section ─── */
  .solutions {
    position: relative;
    overflow: hidden;
    padding: var(--space-1000) var(--space-1000);
    background-color: var(--color-bg-app);
  }

  /* ─── Headings ─── */
  .solutions__headings {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-100);
    text-align: center;
    max-width: var(--max-site-width);
    margin-inline: auto;
    width: 100%;
    margin-bottom: var(--space-1000);
  }

  .solutions__headline {
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: var(--text-h1);
    line-height: var(--leading-h1);
    color: var(--color-text-primary);
    max-width: 960px;
    margin: 0;
  }

  .solutions__subline {
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-h3);
    line-height: var(--leading-h3);
    color: var(--color-text-secondary);
    max-width: 960px;
    margin: 0;
  }

  /* ─── Container ─── */
  .solutions__container {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: var(--space-200);
    margin: 0 auto;
    max-width: var(--max-site-width);
    width: 100%;
    overflow: visible;
  }

  /* ─── Row ─── */
  .solutions__row {
    display: flex;
    align-items: stretch;
    width: 100%;
    overflow: visible;
  }

  /* ─── Cards ─── */
  .solutions__card {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-100);
    justify-content: center;
    padding: var(--space-300);
    background-color: var(--color-bg-card);
    border-radius: var(--radius-300);
    box-shadow: var(--shadow-xxl);
    overflow: visible;
  }

  .solutions__card--challenge {
    border-right: var(--border-xl) solid #FFD9E3;
  }

  .solutions__card--solution {
    border-left: var(--border-xl) solid #E1F7D8;
  }

  .solutions__card-title {
    font-family: var(--font-body);
    font-weight: var(--weight-bold);
    font-size: var(--text-body-lg);
    line-height: var(--leading-body-lg);
    color: var(--color-text-primary);
    letter-spacing: 0.5px;
    margin: 0;
  }

  .solutions__card-text {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-body-md);
    line-height: var(--leading-body-md);
    color: var(--color-text-secondary);
    letter-spacing: 0.5px;
    margin: 0;
  }

  /* ─── Connector ─── */
  .solutions__connector {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    align-self: center;
    margin-left: -10px;
  }

  .solutions__connector-start,
  .solutions__connector-circle,
  .solutions__connector-end {
    display: block;
    flex-shrink: 0;
  }

  .solutions__connector-start img,
  .solutions__connector-circle img,
  .solutions__connector-end img {
    display: block;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .solutions {
      padding: var(--space-500) var(--space-200);
    }

    .solutions__headings {
      margin-bottom: var(--space-500);
    }

    .solutions__headline {
      font-size: var(--text-h2);
      line-height: var(--leading-h2);
    }

    .solutions__subline {
      font-size: var(--text-h4);
      line-height: var(--leading-h4);
    }

    .solutions__row {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }

    .solutions__card {
      border-radius: var(--radius-200);
    }

    .solutions__card--challenge {
      border-right: none;
      border-bottom: var(--border-xl) solid #FFD9E3;
    }

    .solutions__card--solution {
      border-left: none;
      border-top: var(--border-xl) solid #E1F7D8;
    }

    .solutions__connector {
      flex-direction: column;
      width: auto;
      padding: var(--space-100) 0;
      margin-left: 0;
      margin-top: -10px;
    }
  }
</style>
