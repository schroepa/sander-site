---
import type { CertificatesSectionData } from "../lib/grav";
import { GRAV_MEDIA_BASE } from "../lib/grav";

interface Props {
    data: CertificatesSectionData;
}

const { data } = Astro.props;
const items = data.items ?? [];
const itemColor = data.logo_color || "#f1eef0";

const bgVideo = data.background_video
    ? `${GRAV_MEDIA_BASE}/${data.background_video.split('/').pop()}`
    : null;

const bgImage = !bgVideo && data.background_image
    ? `${GRAV_MEDIA_BASE}/${data.background_image.split('/').pop()}`
    : null;

const hasOverlay =
    data.background_overlay !== false &&
    data.background_overlay !== 0 &&
    data.background_overlay !== "0";
---

<section class="certs" id="certificates">
    {(bgVideo || bgImage) && (
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            {bgVideo && (
                <video src={bgVideo} autoplay muted loop playsinline preload="none" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {bgImage && (
                <img src={bgImage} alt="" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {hasOverlay && (
                <div class="absolute inset-0" style="background-color: var(--color-background-overlay);" />
            )}
        </div>
    )}
    {data.headline && <h2 class="certs__headline">{data.headline}</h2>}

    <div class="certs__track-wrapper">
        <div class="certs__track" id="certs-track">
            {
                items.map((item) => {
                    const src = item.image
                        ? `${GRAV_MEDIA_BASE}/${item.image}`
                        : null;
                    return src ? (
                        <div class="certs__item" title={item.name}>
                            <div
                                class="certs__icon"
                                style={`
                -webkit-mask-image: url('${src}');
                mask-image: url('${src}');
                background-color: ${itemColor};
              `}
                                role="img"
                                aria-label={item.name}
                            />
                        </div>
                    ) : null;
                })
            }
        </div>
    </div>
</section>

<script>
    const track = document.getElementById("certs-track");
    if (track && track.children.length > 0) {
        const originalItems = Array.from(track.children);

        // Clone until track is at least 2× viewport wide
        while (track.scrollWidth < window.innerWidth * 2) {
            originalItems.forEach((item) =>
                track.appendChild(item.cloneNode(true)),
            );
        }

        // Duplicate full track → two identical halves, -50% loops perfectly
        Array.from(track.children).forEach((item) =>
            track.appendChild(item.cloneNode(true)),
        );

        // Set duration based on pixel speed (50px/s)
        const halfWidth = track.scrollWidth / 2;
        const pxPerSecond = 50;
        const duration = halfWidth / pxPerSecond;
        track.style.setProperty("--marquee-duration", `${duration}s`);
    }
</script>

<style>
    /* ─── Section ─── */
    .certs {
        position: relative;
        overflow: hidden;
        background-color: var(--color-background-elevation2);
        padding: var(--space-800) var(--space-400);
        border-top: 1px solid var(--color-stroke-tertiary);
        border-bottom: 1px solid var(--color-stroke-tertiary);
    }

    .certs__headline {
        position: relative;
        z-index: 10;
        font-family: var(--font-heading);
        font-weight: var(--weight-bold);
        font-size: var(--text-h3);
        line-height: var(--leading-h3);
        color: var(--color-text-primary);
        text-align: center;
        margin: 0 0 var(--space-600);
    }

    /* ─── Marquee wrapper ─── */
    .certs__track-wrapper {
        position: relative;
        z-index: 10;
        padding: 0 var(--space-500) var(--space-1000);
        width: 100%;
        overflow: hidden;
        /* Fade edges */
        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
    }

    /* ─── Scrolling track ─── */
    .certs__track {
        display: flex;
        align-items: center;
        width: max-content;
        animation: certs-marquee var(--marquee-duration, 60s) linear infinite;
    }

    .certs__track:hover {
        animation-play-state: paused;
    }

    @keyframes certs-marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    /* ─── Single item ─── */
    .certs__item {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 48px;
        padding-right: var(--space-800);
    }

    /* ─── Icon via CSS mask (allows color override) ─── */
    .certs__icon {
        width: 120px;
        height: 48px;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        transition: opacity 0.3s ease;
    }

    .certs__item:hover .certs__icon {
        opacity: 0.7;
    }

    /* ─── Responsive ─── */
    @media (max-width: 768px) {
        .certs {
            padding: var(--space-600) var(--space-200);
        }

        .certs__headline {
            font-size: var(--text-h4);
            line-height: var(--leading-h4);
            margin-bottom: var(--space-400);
        }

        .certs__icon {
            width: 80px;
            height: 36px;
        }

        .certs__item {
            height: 36px;
            padding-right: var(--space-600);
        }
    }
</style>
