---
import Layout from "../layouts/Layout.astro";
import { getImpressum } from "../lib/grav";

const page = getImpressum();

/** Convert plain text with newlines to individual lines (for addresses) */
function textToLines(text: string): string[] {
  return text.split(/\n/).map((l) => l.trim()).filter(Boolean);
}
---

<Layout
  title={page?.title ?? "Impressum – Sander Catering"}
  description={page?.meta_description ??
    "Impressum der Sander Betriebsgastronomie"}
>
  <main class="legal-page">
    <div class="legal-container">
      <a href="/" class="back-link">
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M10 12L6 8l4-4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Zurück zur Startseite
      </a>
      <h1 class="legal-title">{page?.title ?? "Impressum"}</h1>

      <div class="legal-body">

        <!-- Angaben §5 TMG -->
        {(page?.company_name || page?.company_address) && (
          <section>
            <h2>Angaben gemäß § 5 TMG</h2>
            {page.company_name && <p><strong>{page.company_name}</strong></p>}
            {page.company_address && (
              <p>
                {textToLines(page.company_address).map((line, i) => (
                  <>{i > 0 && <br />}{line}</>
                ))}
              </p>
            )}
            {page.company_representatives && (
              <p>
                <strong>Vertreten durch:</strong><br />
                Geschäftsführer: {page.company_representatives}
              </p>
            )}
          </section>
        )}

        <hr />

        <!-- Kontakt -->
        {(page?.contact_phone || page?.contact_email) && (
          <section>
            <h2>Kontakt</h2>
            {page.contact_phone && <p>Telefon: {page.contact_phone}</p>}
            {page.contact_email && (
              <p>E-Mail: <a href={`mailto:${page.contact_email}`}>{page.contact_email}</a></p>
            )}
          </section>
        )}

        <hr />

        <!-- Registereintrag -->
        {(page?.register_court || page?.register_number) && (
          <section>
            <h2>Registereintrag</h2>
            <p>Eintragung im Handelsregister.</p>
            {page.register_court && <p>Registergericht: {page.register_court}</p>}
            {page.register_number && <p>Registernummer: {page.register_number}</p>}
          </section>
        )}

        <hr />

        <!-- EU-Streitschlichtung -->
        {page?.eu_os_link && (
          <section>
            <h2>EU-Streitschlichtung</h2>
            <p>
              Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:{" "}
              <a href={page.eu_os_link} target="_blank" rel="noopener noreferrer">{page.eu_os_link}</a>
            </p>
            <p>Unsere E-Mail-Adresse finden Sie oben im Impressum.</p>
          </section>
        )}

        <!-- Weitere Abschnitte -->
        {page?.sections?.map((section) => (
          <>
            <hr />
            <section>
              <h2>{section.title}</h2>
              {section.body && (
                <div class="markdown-content"><Fragment set:html={section.body} /></div>
              )}
            </section>
          </>
        ))}

      </div>
    </div>
  </main>
</Layout>

<style>
  .legal-page {
    min-height: 100vh;
    background-color: var(--color-background-primary);
    padding: var(--space-1000) var(--space-300);
  }
  .legal-container {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-500);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-100);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease;
    width: fit-content;
  }
  .back-link:hover {
    color: var(--color-text-secondary);
  }
  .legal-title {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    line-height: var(--leading-h1);
    color: var(--color-text-primary);
    margin: 0;
  }
  .legal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-body-md);
    color: var(--color-text-secondary);
  }
  .legal-body :global(section) {
    display: flex;
    flex-direction: column;
    gap: var(--space-200);
  }
  .legal-body :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    line-height: var(--leading-h3);
    color: var(--color-text-primary);
    margin: 0;
  }
  .legal-body :global(p) {
    margin: 0;
    color: var(--color-text-secondary);
  }
  .legal-body :global(strong) {
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
  }
  .legal-body :global(a) {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }
  .legal-body :global(a:hover) {
    color: var(--color-text-primary);
  }
  .legal-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-stroke-secondary);
    margin: var(--space-100) 0;
  }
  @media (max-width: 640px) {
    .legal-page {
      padding: var(--space-800) var(--space-200);
    }
    .legal-title {
      font-size: var(--text-h2);
      line-height: var(--leading-h2);
    }
  }
</style>
