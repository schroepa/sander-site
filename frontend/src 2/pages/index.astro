---
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Header } from "@/components/Header";
import { Hero } from "@/components/Hero";

// 1. Fetch all pages from the 'pages' collection
const pages = await getCollection("pages");

// 2. Find the Home Page
// content ID is sanitized (e.g. '01home/default')
const homePage = pages.find((page) => page.id.includes("01home"));

if (!homePage) {
	throw new Error(
		`Could not find homepage content in CMS. Available IDs: ${pages.map((p) => p.id).join(", ")}`,
	);
}

// 3. Render the Markdown content
const { Content } = await render(homePage);
const { title } = homePage.data;
---

<Layout title={title}>
	<Header client:load />

	<main class="min-h-screen bg-background text-foreground">
		<Hero client:load />

		<article class="container mx-auto px-6 py-20 max-w-4xl space-y-12">
			<!-- Separator / Context -->
			<div class="flex items-center gap-4 text-muted-foreground">
				<div class="h-px flex-1 bg-border"></div>
				<span class="text-sm font-medium uppercase tracking-widest"
					>CMS Content</span
				>
				<div class="h-px flex-1 bg-border"></div>
			</div>

			<!-- Header Section (from Grav Content) -->
			<header class="text-center space-y-4">
				<div
					class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium"
				>
					Editable via Grav CMS
				</div>
				<h2 class="text-4xl font-bold tracking-tight text-primary">
					{title}
				</h2>
			</header>

			<!-- Rendered Markdown Content -->
			<div
				class="prose prose-lg prose-neutral dark:prose-invert max-w-none mx-auto"
			>
				<Content />
			</div>
		</article>
	</main>
</Layout>
